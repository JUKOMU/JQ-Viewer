{
  "name": "jq-viewer",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"src/**/*.{vue,ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,css}\"",
    "check:version": "node scripts/check-version.mjs",
    "build:android": "npm run build && npx cap copy android && cd android && gradlew :app:assembleDebug",
    "build:android:release": "npm run build && ionic capacitor sync android && cd android && gradlew :app:clean && gradlew :app:assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/vue": "^8.0.0",
    "@ionic/vue-router": "^8.0.0",
    "ionicons": "^7.0.0",
    "pdfjs-dist": "^5.6.205",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.3.0",
    "cypress": "^13.5.0",
    "eslint": "^8.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.9.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.2.0",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6",
    "vue-tsc": "^2.1.10"
  },
  "description": "JQViewer - Android 漫画阅读器"
}
